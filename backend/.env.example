# Copie para .env e ajuste. NUNCA comite o .env real.

# Conexão PostgreSQL
DATABASE_URL=postgresql://pnu@localhost:5432/pnu

# Segredo do JWT — gere um valor longo e aleatório em produção
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES=8h

# Porta do servidor
PORT=3001

# Origem do frontend permitida no CORS (Fase 3+)
FRONTEND_URL=http://localhost:5173

# Senha de desenvolvimento aplicada a TODOS os profissionais
# pelo script set-passwords (apenas ambiente de teste).
DEV_PASSWORD=pnu123
